#!/usr/bin/env sh

# Find the lowest free TCP port starting from $1.
# Uses nc (netcat) which is reliable across macOS versions.
free_port() {
  port=${1:-3000}
  while nc -z 127.0.0.1 "$port" 2>/dev/null; do
    port=$((port + 1))
  done
  echo "$port"
}

# Rails port — honour explicit PORT, otherwise auto-detect from 3000.
# Thruster (bin/thrust) will listen on PORT and proxy to Puma on PORT+100.
if [ -z "$PORT" ]; then
  PORT=$(free_port 3000)
fi

# Vite port — honour explicit VITE_RUBY_PORT, otherwise auto-detect from 3036.
if [ -z "$VITE_RUBY_PORT" ]; then
  VITE_RUBY_PORT=$(free_port 3036)
fi

export PORT
export VITE_RUBY_PORT

echo ""
echo "  App  →  http://localhost:$PORT"
echo "  Vite →  http://localhost:$VITE_RUBY_PORT"
echo ""

if command -v overmind 1> /dev/null 2>&1
then
  overmind start -f Procfile.dev "$@"
  exit $?
fi

if command -v hivemind 1> /dev/null 2>&1
then
  exec hivemind Procfile.dev "$@"
  exit $?
fi

if gem list --no-installed --exact --silent foreman; then
  echo "Installing foreman..."
  gem install foreman
fi

foreman start -f Procfile.dev "$@"
